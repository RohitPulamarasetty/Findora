# ════════════════════════════════════════════════════════════════
# Findora — Environment Variables Template
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ════════════════════════════════════════════════════════════════

# ── App ──────────────────────────────────────────────────────────
# CRITICAL for SEO: in production, set this to your real domain (e.g.
# https://findora.live). Used for metadataBase, canonical URLs, OG image
# URLs, robots.txt, and sitemap.xml. If left as localhost in production,
# social previews (WhatsApp/Discord/X/LinkedIn) will all break.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── SEO / Search Console verification (optional) ──────────────────
# After deploying, add the verification strings from Google Search
# Console and Bing Webmaster Tools. Both render as <meta> tags in the
# document head. Safe to expose to the browser.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_BING_SITE_VERIFICATION=

# ── Supabase (public — safe to expose in browser) ────────────────
# Found in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ── Supabase (server-only — NEVER expose to browser) ─────────────
# Found in: Supabase Dashboard → Project Settings → API
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Used for verifying JWTs server-side
SUPABASE_JWT_SECRET=your-jwt-secret-here

# ── Auth & Domain Restriction ─────────────────────────────────────
# Only users with this email domain are allowed to register.
# Example: ds.study.iitm.ac.in
#
# Server-side (auth callback enforces this hard):
ALLOWED_EMAIL_DOMAIN=ds.study.iitm.ac.in
#
# Client-side hint forwarded to Google's account picker (`hd=` param).
# Should match ALLOWED_EMAIL_DOMAIN. Safe to expose to browser.
NEXT_PUBLIC_ALLOWED_EMAIL_DOMAIN=ds.study.iitm.ac.in

# Google OAuth client credentials (configured in Supabase dashboard,
# but kept here for reference / custom OAuth flows)
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── Storage ───────────────────────────────────────────────────────
# Supabase Storage bucket name for item images
SUPABASE_STORAGE_BUCKET=item-images

# ── Rate Limiting ─────────────────────────────────────────────────
# Max item reports per user per hour (Supabase-side soft limit).
RATE_LIMIT_ITEMS_PER_HOUR=3

# Edge rate-limiting via Upstash Redis. REQUIRED in production — when
# unset, the limiter fails open and the app behaves as if no limit is in
# place (acceptable for local dev). Get these from the Upstash dashboard:
# https://console.upstash.com/redis → your DB → REST API.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Support / Donations (Razorpay Standard Checkout) ──────────────
# Get these from: Razorpay Dashboard → Settings → API Keys
# NEXT_PUBLIC_RAZORPAY_KEY_ID is sent to the browser (safe).
# RAZORPAY_KEY_SECRET is server-only — NEVER expose to the browser.
#
# For local development / staging, use test keys (rzp_test_...).
# For production, REPLACE these with LIVE keys (rzp_live_...) from
# the Razorpay dashboard AFTER your account is activated/approved.
# DO NOT commit live keys — set them only in your hosting provider's
# environment-variable settings (e.g. Vercel Project Settings → Env).
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-key-secret

# ── Contact ───────────────────────────────────────────────────────
# Shown on the public Contact page.
NEXT_PUBLIC_CONTACT_EMAIL=rohitpulamarasetty@gmail.com
NEXT_PUBLIC_GITHUB_REPO=https://github.com/RohitPulamarasetty/Findora

# ── Environment ───────────────────────────────────────────────────
# Values: development | staging | production
NODE_ENV=development

# ── Observability (optional, recommended in prod) ─────────────────
# Sentry DSN — when set, server + client errors are forwarded to Sentry
# via @sentry/nextjs (install with `npm i @sentry/nextjs` to enable).
# When unset, src/lib/logger.ts falls back to structured JSON to stdout
# (Vercel log explorer picks it up natively).
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# ── Operational secrets ───────────────────────────────────────────
# Shared secret for /api/cron/* endpoints. Vercel cron sends it as
# `Authorization: Bearer ${CRON_SECRET}` automatically when this env
# var is set on the project. Generate with:
#   openssl rand -hex 32
CRON_SECRET=

# ── Analytics ─────────────────────────────────────────────────────
# Google Analytics 4 — Measurement ID found in:
#   GA4 Dashboard → Admin → Data Streams → your stream → Measurement ID
# Format: G-XXXXXXXXXX
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
# Microsoft Clarity — Project ID found in:
#   clarity.microsoft.com → your project → Settings → Overview
NEXT_PUBLIC_CLARITY_ID=your-clarity-project-id
